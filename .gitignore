# すべてのファイルをデフォルトで無視
### all ignore ###
/*
/.**

# 管理対象のファイルをホワイトリストとして追記
### not ignore ###

# Zsh
!/.zshrc
!/.zshenv
!/.zprofile

# Vim
!/.vimrc

# tmux
!/.tmux.conf

# Git
!/.gitconfig
!/.gitignore_global

# Claude Code (user-global config, symlinked to ~/.claude/ by install.sh)
!/.config/
!/.config/claude/
!/.config/claude/settings.json
!/.config/claude/statusline-command.sh
!/.config/claude/skills/
!/.config/claude/skills/**

# Gemini CLI (user-global config, symlinked to ~/.gemini/ by install.sh)
!/.config/gemini/
!/.config/gemini/settings.json

# OpenAI Codex (user-global config, symlinked to ~/.codex/ by install.sh)
!/.config/codex/
!/.config/codex/config.toml

# Scripts
!/.bin/
!/.bin/**

# CI
!/.github/**

# Repo files
!/README.md
!/LICENSE
!/CLAUDE.md
!.gitignore
!.gitkeep
